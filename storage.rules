rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ================================
    // Utility Functions
    // ================================
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isValidImage() {
      return resource.contentType.matches('image/.*');
    }
    
    function isValidSize(maxMB) {
      return resource.size < maxMB * 1024 * 1024;
    }

    // ================================
    // User Files
    // ================================
    
    // User avatars are public readable, but only writable by the owner.
    match /user-avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidImage() && isValidSize(5);
    }
    
    // Other user-specific uploads can only be accessed by the owner.
    match /user-uploads/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
    
    // ================================
    // Agreement Files
    // ================================
    
    // Allow any authenticated user to read/write agreement files.
    // In a real-world app, you'd want to restrict this to agreement members.
    match /agreement-files/{agreementId}/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
