rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /agreements/{agreementId} {
      // Allow creation if the user ID in the new document matches the authenticated user's ID.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Allow read, update, and delete only if the user ID in the existing document matches.
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /users/{userId} {
      // Allow anyone authenticated to create a user profile (e.g., on signup) and read profiles.
      allow read, create: if request.auth != null;
      
      // Allow users to only update or delete their own profile.
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
