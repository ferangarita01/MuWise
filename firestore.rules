rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own user document, and can create it.
    // They cannot update or delete it through these rules, nor see other user docs.
    match /users/{userId} {
      allow read, create: if request.auth != null && request.auth.uid == userId;
    }

    // Users can create, read, update, and delete agreements
    // where their userId matches the one on the document.
    match /agreements/{agreementId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
