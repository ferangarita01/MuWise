rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ================================
    // FUNCIONES DE UTILIDAD
    // ================================
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.get('role', '') == 'admin';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isValidUserData() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'displayName', 'email']) &&
             data.uid is string &&
             data.displayName is string &&
             data.email is string &&
             data.email.matches('.*@.*\\..*');
    }
    
    function isValidAgreementData() {
      let data = request.resource.data;
      return data.keys().hasAll(['userId', 'songTitle', 'status']) &&
             data.userId is string &&
             data.songTitle is string &&
             data.status in ['Draft', 'Sent', 'Partial', 'Signed', 'Archived'] &&
             data.userId == request.auth.uid;
    }
    
    function isCollaborator(agreementData) {
      return request.auth != null &&
             agreementData.composers != null &&
             agreementData.composers is list &&
             request.auth.token.email in agreementData.composers[0].email;
    }

    // ================================
    // USUARIOS
    // ================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if request.auth != null;

      allow update: if isOwner(userId) || isAdmin();
      
      allow delete: if isAdmin();
    }

    // ================================
    // ACUERDOS MUSICALES
    // ================================
    
    match /agreements/{agreementId} {
      allow read: if request.auth != null || 
                     (resource != null && resource.data.get('allowPublicAccess', false) == true);
      
      allow create: if request.auth != null && 
                       isValidAgreementData();
      
      allow update: if request.auth != null && 
                       (isOwner(resource.data.get('userId', '')) || 
                        isAdmin() ||
                        (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['composers', 'status']) && 
                         resource.data.get('allowPublicAccess', false) == true));
      
      allow delete: if request.auth != null && 
                       (isOwner(resource.data.get('userId', '')) || isAdmin());
    }

    // ================================
    // TOKENS DE FIRMA
    // ================================
    
    match /signing-tokens/{tokenId} {
      allow read: if false;
      
      allow create: if request.auth != null &&
                       request.resource.data.createdBy == request.auth.uid;
      
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['used', 'usedAt']) &&
                       request.resource.data.used == true &&
                       resource.data.used == false;
      
      allow delete: if false;
    }

    // ================================
    // METADATOS DE ARCHIVOS
    // ================================
    
    match /file-metadata/{fileId} {
      allow read: if request.auth != null && 
                     (isOwner(resource.data.get('uploadedBy', '')) || isAdmin());
      
      allow create: if request.auth != null && 
                       request.resource.data.uploadedBy == request.auth.uid &&
                       request.resource.data.uploadedBy is string &&
                       request.resource.data.category in ['split-sheet', 'contract', 'photo', 'document', 'avatar', 'agreement-attachment', 'temp'];
      
      allow update: if request.auth != null && 
                       (isOwner(resource.data.get('uploadedBy', '')) || isAdmin()) &&
                       request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['tags', 'description', 'processed', 'processedAt', 
                               'analysisResult', 'downloadCount', 'lastAccessedAt', 'lastAccessedBy']);
      
      allow delete: if request.auth != null && 
                       (isOwner(resource.data.get('uploadedBy', '')) || isAdmin());
    }

    // ================================
    // LOGS DE AUDITORÍA
    // ================================
    
    match /audit-logs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if false;
    }

    // ================================
    // COLECCIONES ADICIONALES (FUTURO)
    // ================================
    
    match /agreement-templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /user-notifications/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId);
    }

    // ================================
    // SEGURIDAD: BLOQUEAR TODO LO DEMÁS
    // ================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
